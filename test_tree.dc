int main(){
  int depth;
  int size;
  int* leaves;
  int addr;
  int i;
  int path[3];

  depth = 3;
  size = 1 << depth;
  leaves = malloc(32);

  for(i = 0; i < size; i = i + 1){
    leaves[i] = 0;
  }

  path[0] = 1;
  path[1] = 0;
  path[2] = 1;

  addr = 0;
  for(i = 0; i < depth; i = i + 1){
    addr = (addr << 1) | path[i];
  }

  leaves[addr] = 42;

  return leaves[5];
}
